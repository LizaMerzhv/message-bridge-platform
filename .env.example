# ======================================================================
# Database credentials for API service
# ======================================================================
API_DB_USER=notifi_api
API_DB_PASSWORD=notifi_api_password
API_DB_SCHEMA=public

# ======================================================================
# Database credentials for Worker service
# ======================================================================
WORKER_DB_USER=notifi_worker
WORKER_DB_PASSWORD=notifi_worker_password
WORKER_DB_SCHEMA=public

# ======================================================================
# Database credentials for Security service
# ======================================================================
SECURITY_DB_USER=notifi_security
SECURITY_DB_PASSWORD=notifi_security_password
SECURITY_DB_SCHEMA=public

# ======================================================================
# RabbitMQ broker defaults
# ======================================================================
RABBITMQ_DEFAULT_USER=notifi_rabbit
RABBITMQ_DEFAULT_PASS=notifi_rabbit_password

# ======================================================================
# Messaging settings (exchange / routing keys)
# ======================================================================
API_AMQP_EXCHANGE=notifi.exchange
API_AMQP_INGEST_ROUTING_KEY=ingest

WORKER_AMQP_EXCHANGE=notifi.exchange
WORKER_AMQP_INGEST_ROUTING_KEY=ingest

# ======================================================================
# SMTP settings for Mailhog (local demo only)
# ======================================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ======================================================================
# Demo API client key (used by Flyway seed migration)
# ======================================================================
NOTIFI_DEMO_API_KEY=demo-123

# ======================================================================
# Admin user for HTTP Basic access to /admin and /actuator
# DO NOT reuse these values in production.
# ======================================================================
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=changeit

# ======================================================================
# Gateway settings
# ======================================================================
API_GATEWAY_PORT=8080
API_SERVICE_URL=http://api:8080
SECURITY_SERVICE_URL=http://security-service:8080
API_GATEWAY_SHARED_SECRET=notifi-gateway-dev-secret
